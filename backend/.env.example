# ════════════════════════════════════════════════════════════════════════════
# QueryMind AI — SQL Analyst MCP Server
# Environment Configuration (.env)
# ════════════════════════════════════════════════════════════════════════════

# ── DATABASE ─────────────────────────────────────────────────────────────────
# Central PostgreSQL database (hosts: users table, audit logs, central metadata)
# Format: postgresql://username:password@hostname:port/databasename
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sqlanalyst
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_QUERY_TIMEOUT_SECONDS=30

# Enable SQL logging (development only)
SQL_ECHO=false

# ── API AUTHENTICATION ───────────────────────────────────────────────────────
# JWT configuration
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080  # 7 days

# ── SECURITY ─────────────────────────────────────────────────────────────────
# Application environment
APP_ENV=development  # or production
APP_NAME=QueryMind AI
SECRET_KEY=super-secret-key-change-in-production

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── AI/LLM INTEGRATION ───────────────────────────────────────────────────────
# Groq API (free, high-throughput inference)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192  # or mixtral-8x7b-32768

# ── QUERY LIMITS ─────────────────────────────────────────────────────────────
# Maximum rows returned per query
MAX_RESULT_ROWS=1000

# Query timeout (seconds)
QUERY_TIMEOUT_SECONDS=30

# Maximum connections per user database
MAX_USER_CONNECTIONS=5

# ── CACHING (Optional — for Redis support) ──────────────────────────────────
ENABLE_REDIS=false
REDIS_URL=redis://localhost:6379/0

# ── LOGGING ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/app.log

# ── FEATURE FLAGS ────────────────────────────────────────────────────────────
# Enable/disable specific features
ENABLE_AUDIT_LOGGING=true
ENABLE_QUERY_CACHING=true
ENABLE_QUERY_VALIDATION=true
ENABLE_STREAMING_RESPONSES=true

# ── DEVELOPMENT ──────────────────────────────────────────────────────────────
# Debug mode
DEBUG=false

# Reload on file change (development only)
RELOAD=true
